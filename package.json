{
  "name": "valiss",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript implementation of the valiss authentication scheme (wire spec 1)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
